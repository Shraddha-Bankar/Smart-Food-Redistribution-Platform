# OpenRouter API key for the AI Assistant feature
# Get one free at https://openrouter.ai/keys
# If left empty, the AI Assistant runs in demo mode with canned responses
VITE_OPENROUTER_API_KEY=

# Optional: change the model used (default: anthropic/claude-3.5-sonnet)
# Browse available models at https://openrouter.ai/models
VITE_OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
